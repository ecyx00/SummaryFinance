# Google Gemini API Key
GOOGLE_API_KEY=your_api_key_here

# Guardian API ayarları
GUARDIAN_API_KEY=your_guardian_api_key_here
GUARDIAN_API_URL=https://content.guardianapis.com/search

# Gemini API ayarları
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent

# Spring Boot backend ayarları
BACKEND_URL=http://localhost:8080
BACKEND_API_PATH=/api/v1

# Veritabanı ayarları (doğrudan veritabanına erişim gerekirse)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=summaryfinance
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# Loglama ayarları
LOG_LEVEL=INFO
LOG_FILE=ai-service.log

# Servis ayarları
FETCH_INTERVAL=10800  # Saniye cinsinden (3 saat)
REQUEST_TIMEOUT=30    # Saniye cinsinden

# CORS ayarları (Python servisi için web sunucusu gerekirse)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
